{
  "name": "reed-archive",
  "version": "0.1.0",
  "private": true,
  "description": "See <https://www.theobeers.com/reed-archive/>",
  "homepage": "https://github.com/theodore-s-beers/reed-archive#readme",
  "bugs": {
    "url": "https://github.com/theodore-s-beers/reed-archive/issues"
  },
  "license": "MIT",
  "author": "Theo Beers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theodore-s-beers/reed-archive.git"
  },
  "main": "index.html",
  "scripts": {
    "format": "oxfmt",
    "format-html": "oxfmt '**/index.html'",
    "lint": "oxfmt --check && oxlint",
    "lint-css": "stylelint --fix styles.css",
    "minify-html": "fd index.html -x html-minifier-next {} --collapse-whitespace --minify-css true --remove-comments -o {}",
    "test": "echo 'Error: no test specified' && exit 1"
  },
  "devDependencies": {
    "html-minifier-next": "^7.0.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
